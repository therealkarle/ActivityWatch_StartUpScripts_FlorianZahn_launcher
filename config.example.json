{
  "logging": {
    "saveTerminalOutputToLog": true
  },
  "startupTimeMonitor": {
    "enabled": true
  },
  "blocks": [
    {
      "type": "delay",
      "seconds": 30,
      "note": "Wait after login before starting the first step."
    },
    {
      "type": "activityWatchCheck",
      "url": "http://localhost:5600",
      "retryDelaySeconds": 30,
      "maxRetries": 8,
      "note": "Wait until ActivityWatch is online before running the next step."
    },
    {
      "type": "step",
      "name": "sync",
      "scripts": [
        {
          "name": "Generic Sync Script",
          "path": "C:\\Path\\To\\Your\\Project\\sync_script.py",
          "enabled": true
        },
        {
          "name": "Optional Disabled Script",
          "path": "C:\\Path\\To\\Your\\Project\\optional_script.py",
          "enabled": false,
          "note": "Disabled without deleting the entry."
        }
      ]
    },
    {
      "type": "delay",
      "seconds": 300,
      "note": "Pause before the export step."
    },
    {
      "type": "step",
      "name": "export",
      "scripts": [
        {
          "name": "Generic Export Script",
          "path": "C:\\Path\\To\\Your\\Project\\export_script.py",
          "enabled": true
        }
      ]
    }
  ]
}
